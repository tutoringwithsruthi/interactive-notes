    border-radius: 10px;
    padding: 1rem 1.1rem;
  }
  .practice-icon {
    font-size: 20px;
    margin-bottom: 6px;
  }
  .practice-title {
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 4px;
    color: var(--accent);
  }
  .practice-desc {
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.5;
  }

  /* ── ELECTRON CONFIG DISPLAY ── */
  .config-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;

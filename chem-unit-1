    padding-top: 1px;
  }
  .vocab-def { color: var(--text); line-height: 1.5; }

  /* ── ATOM DIAGRAM ── */
  .atom-svg { display: block; margin: 0 auto 1rem; }

  /* ── DIVIDER ── */
  .divider {

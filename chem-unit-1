  }
  @media (max-width: 540px) {
    .two-col { grid-template-columns: 1fr; }
  }

  /* ── VOCAB GRID ── */
  .vocab { display: flex; flex-direction: column; gap: 6px; }
  .vocab-item {
    display: flex;
    gap: 10px;

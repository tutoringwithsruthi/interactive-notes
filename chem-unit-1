  <!-- ═══ QUICK REFERENCE ═══ -->
  <div class="section">
    <div class="section-head">
      <div class="section-num">★</div>
      <div class="section-title">Quick-Reference Formulas</div>
    </div>
    <div class="formula-box">
      Atomic Number        = # protons<br>
      Mass Number          = # protons + # neutrons<br>
      # Neutrons           = Mass Number − Atomic Number<br>
      Charge of ion        = # protons − # electrons<br>
      Atomic Mass          = Σ (mass of isotope × fractional abundance)<br>
      Fractional abundance = % / 100
    </div>
  </div>


  .config-box.filled { background: var(--highlight2); border-color: var(--accent); color: var(--accent); font-weight: 600; }
  .config-box.excited { background: #FDECEA; border-color: var(--accent2); color: var(--accent2); font-weight: 600; }
  .config-box.empty { background: #FAFAF8; color: var(--muted); }

  .footer-bar {
    text-align: center;
